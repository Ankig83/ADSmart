# ADSmart — переменные окружения
# Скопируй в .env и заполни значения

# Обязательные
SECRET_KEY=your-secret-key-change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://example.com

# База данных (пусто = SQLite для dev)
# DATABASE_URL=postgres://user:password@localhost:5432/adsmart_db

# Email — оповещение админа о заявках
# Dev: оставь EMAIL_BACKEND пустым — используется console (письма в stdout)
# Prod: укажи smtp backend и настройки
ADMIN_LEAD_EMAIL=welcome@ad-smart.ru
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ad-smart.ru

# Язык и часовой пояс
# LANGUAGE_CODE=ru-ru
# TIME_ZONE=Europe/Moscow
