# ADSmart — переменные окружения
# Скопируй в .env и заполни значения

# Обязательные
SECRET_KEY=your-secret-key-change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://example.com

# База данных (пусто = SQLite для dev)
# DATABASE_URL=postgres://user:password@localhost:5432/adsmart_db

# Email — оповещение админов о заявках (Gmail)
# Список получателей ADMIN_EMAILS задаётся в adsmart/settings.py
# Dev: оставь EMAIL_BACKEND пустым — письма в консоль
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=kunichkin83@gmail.com
EMAIL_HOST_PASSWORD=пароль_приложения_gmail
DEFAULT_FROM_EMAIL=ADSmart <kunichkin83@gmail.com>

# Контакты в подвале: 1) телефон (tel:), 2) канал Telegram, 3) почта (mailto:)
# CONTACT_PHONE=79179816000
# CONTACT_PHONE_DISPLAY=+7 (917) 981-60-00
# CONTACT_TELEGRAM_CHANNEL=artm_medvedev   (slug канала, без t.me/)
# CONTACT_EMAIL=welcome@ad-smart.ru

# Кейсы: по умолчанию в коде заданы два документа Google Docs.
# Со страницы Telegram → TELEGRAM_CASES_URL (кейсы ТГ).
# С остальных страниц и в подвале → CASES_URL (кейсы ADSmart/Twin).
# Переопредели через .env при необходимости.
# TELEGRAM_CASES_URL=https://docs.google.com/document/d/1XgtH0kbz_ENKITt01irpXKrjUFLgXDu-JC-tv0waQe0/edit?usp=sharing
# CASES_URL=https://docs.google.com/document/d/1247eN8K2uyX-ir4qNdk-6idESXc90xjNnnwVNJRpN6A/edit?usp=sharing

# Язык и часовой пояс
